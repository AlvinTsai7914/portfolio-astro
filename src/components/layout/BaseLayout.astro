---
// ==========================================================================
// BaseLayout — 全站 HTML 骨架
// 職責：<head> 設定、Google Fonts 載入、全域樣式、共用元件（Header/Footer/FloatingSocial）
// ==========================================================================

import { ClientRouter } from "astro:transitions";
import "../../styles/global.scss";
import Header from "./Header.astro";
import MobileMenu from "./MobileMenu.astro";
import Footer from "./Footer.astro";
import FloatingSocial from "../ui/FloatingSocial.astro";

interface Props {
  title: string;
  description?: string;
  lang?: "zh" | "en";
}

const {
  title,
  description = "",
  lang = "zh",
} = Astro.props;

---

<!doctype html>
<html lang={lang === "zh" ? "zh-Hant-TW" : "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Google Fonts: Geist Sans + Geist Mono + BIZ UDGothic + Noto Sans TC + Noto Sans Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=BIZ+UDGothic:wght@400;700&family=Geist:wght@300;400;500;700&family=Geist+Mono:wght@300;400;500;700&family=Noto+Sans+TC:wght@300;400;500;700&family=Noto+Sans+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <Header lang={lang} />
    <MobileMenu lang={lang} />
    <FloatingSocial />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <div id="custom-cursor" class="custom-cursor" aria-hidden="true"
         data-astro-transition-persist="custom-cursor">
      <span id="custom-cursor-text" class="custom-cursor__text"></span>
    </div>
    <!-- 頁面轉場雙色遮罩（persist = 跨頁面保留，不被 DOM swap 替換） -->
    <div class="page-transition" id="page-transition" aria-hidden="true"
         data-astro-transition-persist="page-transition">
      <div class="page-transition__mask page-transition__mask--brand"></div>
      <div class="page-transition__mask page-transition__mask--fg"></div>
    </div>
    <script src="../../scripts/page-transition.ts"></script>
    <script src="../../scripts/hero-ascii.ts"></script>
    <script src="../../scripts/contact-ascii.ts"></script>
    <script src="../../scripts/reveal-animation.ts"></script>
    <script src="../../scripts/smooth-scroll.ts"></script>
    <script src="../../scripts/text-scramble.ts"></script>
    <script src="../../scripts/mobile-menu.ts"></script>
    <script src="../../scripts/custom-cursor.ts"></script>
    <script src="../../scripts/scroll-fade.ts"></script>
    <script src="../../scripts/experience-cursor.ts"></script>
  </body>
</html>
