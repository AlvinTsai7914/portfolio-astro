---
// ==========================================================================
// Header — 固定式頂部導覽
// 來源：docs/design-dna.md 第 7 節、good-fella.com header 行為
//
// 結構：header（外層，無背景）→ header__bar（內層，控制顏色和寬度）
//
// 狀態（由 JS 控制 class）：
// 1. 頂部初始：header__bar 滿版寬度
// 2. .header--scrolled：header__bar 左右 margin 32px，對齊 container
// 3. .header--light / .header--dark：header__bar 切換色彩（#333 / #d5d5d5）
//
// 內容：Logo（左）、Nav（中）、語言切換（右）
// ==========================================================================

interface Props {
  lang?: "zh" | "en";
}

const { lang = "zh" } = Astro.props;

const navItems = [
  { id: "about", label: { zh: "關於", en: "About" } },
  { id: "skills", label: { zh: "技能", en: "Skills" } },
  { id: "projects", label: { zh: "作品", en: "Projects" } },
  { id: "experience", label: { zh: "經歷", en: "Experience" } },
  { id: "contact", label: { zh: "聯繫", en: "Contact" } },
];

const altLang = lang === "zh" ? "en" : "zh";
const altLangPath = `/${altLang}/`;

// 首頁用純錨點（#about），非首頁加上首頁路徑（/zh/#about）
const isHome = Astro.url.pathname === `/${lang}/` || Astro.url.pathname === `/${lang}`;
const navBase = isHome ? "" : `/${lang}/`;
---

<header class="header" id="site-header">
  <div class="header__bar header__bar--dark">
    <div class="header__inner">
      <a href={`/${lang}/`} class="header__logo">
        <span class="header__logo-text" id="header-logo-text">YourName</span>
      </a>

      <nav class="header__nav" aria-label="Main navigation">
        {
          navItems.map((item) => (
            <a href={`${navBase}#${item.id}`} class="header__nav-link">
              {item.label[lang]}
            </a>
          ))
        }
      </nav>

      <button
        class="header__menu-toggle"
        id="header-menu-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="header__menu-toggle-label">MENU</span>
        <span class="header__menu-toggle-icon" aria-hidden="true">
          <span class="header__menu-toggle-line"></span>
          <span class="header__menu-toggle-line"></span>
        </span>
      </button>

      <div class="header__actions">
        <a href={altLangPath} class="header__lang-switch">
          {altLang.toUpperCase()}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // --------------------------------------------------------------------------
  // Header 狀態控制
  // 來源：design-dna.md 第 7 節
  //
  // 1. 滾動偵測：scrollY > 100px → .header--scrolled
  // 2. Section 偵測：IntersectionObserver → .header__bar--light / .header__bar--dark
  // --------------------------------------------------------------------------

  function initHeader() {
    const header = document.getElementById("site-header");
    if (!header) return;

    const bar = header.querySelector<HTMLElement>(".header__bar");
    if (!bar) return;

    const SCROLL_THRESHOLD = 100;

    // 滾動偵測
    function handleScroll() {
      if (window.scrollY > SCROLL_THRESHOLD) {
        header.classList.add("header--scrolled");
      } else {
        header.classList.remove("header--scrolled");
      }
    }

    // Section data-theme 偵測
    function initThemeObserver() {
      const sections = document.querySelectorAll<HTMLElement>("section[data-theme]");
      if (sections.length === 0) return;

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              const theme = (entry.target as HTMLElement).dataset.theme;
              bar.classList.remove("header__bar--light", "header__bar--dark");
              bar.classList.add(`header__bar--${theme}`);
            }
          }
        },
        {
          rootMargin: "0px 0px -95% 0px",
          threshold: 0,
        }
      );

      sections.forEach((section) => observer.observe(section));
    }

    // ------------------------------------------------------------------
    // 入場動畫：隱藏 → 等頁面轉場揭示完成 → ease-out-back 滑入
    // 來源：good-fella.com header 行為（純 CSS transition + class 切換）
    // ------------------------------------------------------------------
    header.classList.add("header--hidden", "header--no-transition");
    void header.offsetHeight; // 強制 reflow，確保 hidden 狀態套用
    header.classList.remove("header--no-transition");

    window.addEventListener(
      "page-revealed",
      () => header.classList.remove("header--hidden"),
      { once: true },
    );

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();
    initThemeObserver();
  }

  initHeader();
  document.addEventListener("astro:page-load", initHeader);
</script>

<style lang="scss">
  // ==========================================================================
  // Header — 外層
  // 無背景色，只負責固定定位和 padding
  // ==========================================================================
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding-top: var(--space-4); // 16px

    // 入場動畫：translateY 控制垂直位移
    // 來源：good-fella.com header 行為
    --header-y: 0%;
    transform: translateY(var(--header-y));
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); // ease-out-back
  }

  // 隱藏狀態：推到畫面上方
  .header--hidden {
    --header-y: -100%;
  }

  // 頁面轉場期間暫停 transition，避免閃爍
  .header--no-transition {
    transition: none;
  }

  // ==========================================================================
  // Header Bar — 內層
  // 控制顏色、寬度和 transition
  // ==========================================================================
  // Mobile-first：56px → Tablet+ 72px
  .header__bar {
    display: flex;
    align-items: center;
    height: 56px;
    padding-inline: var(--space-4);
    margin-inline: 0; // 頂部：滿版
    transition:
      margin 0.4s var(--ease-out),
      background-color 0.3s var(--transition-timing),
      color 0.3s var(--transition-timing);
  }

  // --------------------------------------------------------------------------
  // 色彩狀態：深色區塊上 → 淺色 bar
  // （header 在 dark section 上時，bar 用淺色讓文字可見）
  // --------------------------------------------------------------------------
  .header__bar--dark {
    color: #d5d5d5;
  }

  .header__bar--light {
    color: #333;
  }

  // --------------------------------------------------------------------------
  // Tablet+：恢復桌面尺寸
  // --------------------------------------------------------------------------
  @media (min-width: 768px) {
    .header__bar {
      height: 72px;
      padding-inline: var(--space-8);
    }
  }

  // --------------------------------------------------------------------------
  // 滾動後：左右 margin 收縮，對齊 container
  // --------------------------------------------------------------------------
  .header--scrolled .header__bar {
    margin-inline: var(--grid-margin); // 32px（desktop）

    &.header__bar--dark {
      background-color: rgba(51, 51, 51, 0.85);
      backdrop-filter: blur(12px);
    }

    &.header__bar--light {
      background-color: rgba(213, 213, 213, 0.85);
      backdrop-filter: blur(12px);
    }
  }

  // --------------------------------------------------------------------------
  // Inner Layout
  // --------------------------------------------------------------------------
  // 一律 flex space-between;MENU 按鈕走 absolute 置中(不受 logo/EN 寬度影響)
  .header__inner {
    width: 100%;
    max-width: var(--grid-max-width);
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: var(--space-4);
    position: relative;
  }

  // --------------------------------------------------------------------------
  // Logo
  // --------------------------------------------------------------------------
  .header__logo {
    font-family: var(--font-mono);
    font-size: var(--text-body);
    font-weight: var(--font-weight-medium);
    color: inherit;
    text-decoration: none;
    flex-shrink: 0;
  }

  // --------------------------------------------------------------------------
  // Navigation — 全域隱藏(所有斷點都由 MobileMenu overlay 取代)
  // DOM 保留作為 SEO / 無障礙 fallback,視覺上完全靠 MENU 按鈕展開的 overlay
  // --------------------------------------------------------------------------
  .header__nav {
    display: none;
  }

  .header__nav-link {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    color: inherit;
    text-decoration: none;
    opacity: 0.7;
    transition: opacity var(--transition-duration) var(--transition-timing);

    &:hover {
      opacity: 1;
    }
  }

  // --------------------------------------------------------------------------
  // Lang Switch — 反轉填充 hover
  // --------------------------------------------------------------------------
  .header__actions {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  // --------------------------------------------------------------------------
  // MENU 觸發按鈕(僅手機版顯示)— 文字 "MENU" + 兩條粗線(open 時轉為 ×)
  // 來源:good-fella.com 手機版 header
  // --------------------------------------------------------------------------
  .header__menu-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    font-weight: var(--font-weight-medium);
    color: inherit;
    cursor: pointer;
    letter-spacing: 0.05em;

    // 絕對置中於 header 幾何中心(不受 logo/EN 寬度影響)
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  // Label 固定寬度(容納較長的 "CLOSE"),MENU 時文字置中,避免切換文字時按鈕位置跳動
  .header__menu-toggle-label {
    display: inline-block;
    min-width: 5ch;
    text-align: center;
  }

  .header__menu-toggle-icon {
    position: relative;
    display: inline-block;
    width: 16px;
    height: 8px;
  }

  .header__menu-toggle-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background-color: currentColor;
    transition: transform 0.3s var(--transition-timing);

    &:nth-child(1) { top: 0; }
    &:nth-child(2) { bottom: 0; }
  }

  // 開啟狀態:兩條線交叉成 ×
  .header__menu-toggle.is-open .header__menu-toggle-line:nth-child(1) {
    transform: translateY(3px) rotate(45deg);
  }

  .header__menu-toggle.is-open .header__menu-toggle-line:nth-child(2) {
    transform: translateY(-3px) rotate(-45deg);
  }

  // ==========================================================================
  // Menu 開啟時:bar 套用與 .header--scrolled 相同的「往中間縮」效果
  // (margin-inline 收窄 + 深色半透明背景 + blur + 淺色文字)
  // 覆蓋當前 section data-theme 造成的 bar--light,確保在深色 overlay 上可讀
  // ==========================================================================
  :global(body.menu-open) .header .header__bar {
    margin-inline: var(--grid-margin);
    background-color: rgba(51, 51, 51, 0.85);
    backdrop-filter: blur(12px);
    color: #eee;
  }

  .header__lang-switch {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    font-weight: var(--font-weight-medium);
    color: inherit;
    text-decoration: none;
    padding: var(--space-1) var(--space-2);
    border: 1px solid currentColor;
    opacity: 0.7;
    transition:
      background-color 0.2s var(--transition-timing),
      color 0.2s var(--transition-timing),
      opacity 0.2s var(--transition-timing);

    &:hover {
      opacity: 1;
    }
  }

  // 深色區塊上：hover 填充淺色背景，文字變深
  .header__bar--dark .header__lang-switch:hover {
    background-color: #d5d5d5;
    color: #141314;
    border-color: #d5d5d5;
  }

  // 淺色區塊上：hover 填充深色背景，文字變淺
  .header__bar--light .header__lang-switch:hover {
    background-color: #333;
    color: #eee;
    border-color: #333;
  }
</style>
