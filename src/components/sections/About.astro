---
// ==========================================================================
// About Section
// 來源：design-dna.md 第 4 節（窄版居中 8 欄）、Stitch Screen 676dda1b
//
// 窄版居中：頭像（左）+ 文字（右）
// data-theme="light"
// ==========================================================================

import SectionLabel from "../ui/SectionLabel.astro";
import RevealText from "../ui/RevealText.astro";

interface Props {
  lang?: "zh" | "en";
}

const { lang = "zh" } = Astro.props;

const content = {
  zh: {
    headline: "關於我",
    paragraphs: [
      "前端工程師，跨領域背景。從政府機關、日商汽車品牌、金融到公益單位，習慣在不同產業的節奏與需求中找出共通解。",
      "專注三件事 — 無障礙網站、互動動畫、AI 工作流。相信好的網站不是技術堆疊的結果，而是來自團隊內溝通與解決問題的能力。",
    ],
    stats: [
      { value: "5+", label: "前端年資" },
      { value: "A11y", label: "無障礙" },
      { value: "AI", label: "工作流" },
    ],
  },
  en: {
    headline: "About Me",
    paragraphs: [
      "Frontend developer with a cross-disciplinary background. From government, Japanese automotive brands, finance, to non-profits — I'm used to finding common ground across industries.",
      "Three focuses — accessible web standards, interactive motion, and AI-integrated workflows. I believe great websites come from how a team communicates, not just the stack they pick.",
    ],
    stats: [
      { value: "5+", label: "Years Frontend" },
      { value: "A11y", label: "Compliance" },
      { value: "AI", label: "Workflow" },
    ],
  },
};

const t = content[lang];
---

<section data-theme="light" class="section" id="about">
  <div class="grid">
    <div class="grid-narrow about">
      <div class="about__portrait">
        <div class="about__portrait-placeholder" data-fade-up data-fade-y="60"></div>
      </div>
      <div class="about__content">
        <RevealText delay={0.1}><SectionLabel text="About" /></RevealText>
        <RevealText pt="var(--space-3)" mb="var(--space-6)"><h2 class="about__headline">{t.headline}</h2></RevealText>
        {t.paragraphs.map((p) => <p class="about__text" data-fade-up data-fade-group="about-text" data-fade-trigger=".about__content">{p}</p>)}
        <div class="about__stats">
          {
            t.stats.map((stat) => (
              <div class="about__stat" data-fade-up data-fade-group="about-stats" data-fade-trigger=".about__content">
                <span class="about__stat-value">{stat.value}</span>
                <span class="about__stat-label">{stat.label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .about {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  // --------------------------------------------------------------------------
  // Portrait
  // --------------------------------------------------------------------------
  .about__portrait-placeholder {
    width: 100%;
    max-width: 280px;
    aspect-ratio: 3 / 4;
    background-color: var(--color-surface);
    opacity: 0;
  }

  // --------------------------------------------------------------------------
  // Content
  // --------------------------------------------------------------------------
  .about__headline {
    margin-bottom: var(--space-6);
  }

  .about__text {
    font-size: var(--text-body-lg);
    line-height: 1.5;
    color: var(--color-foreground);
    margin-bottom: var(--space-4);
    max-width: var(--container-2xl);
    opacity: 0;
  }

  // --------------------------------------------------------------------------
  // Stats
  // --------------------------------------------------------------------------
  .about__stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  .about__stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    opacity: 0;
  }

  .about__stat-value {
    font-family: var(--font-mono);
    font-size: var(--text-h4);
    font-weight: var(--font-weight-bold);
    color: var(--color-foreground);
  }

  .about__stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    color: var(--color-foreground-muted);
  }

  // --------------------------------------------------------------------------
  // Responsive — Tablet+（≥ 768px）切換為兩欄佈局
  // --------------------------------------------------------------------------
  @media (min-width: 768px) {
    .about {
      grid-template-columns: 3fr 5fr;
    }

    .about__portrait-placeholder {
      max-width: none;
    }

    .about__stats {
      flex-wrap: nowrap;
    }
  }
</style>
