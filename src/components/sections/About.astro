---
// ==========================================================================
// About Section
// 來源：design-dna.md 第 4 節（窄版居中 8 欄）、Stitch Screen 676dda1b
//
// 窄版居中：頭像（左）+ 文字（右）
// data-theme="light"
// ==========================================================================

import SectionLabel from "../ui/SectionLabel.astro";
import RevealText from "../ui/RevealText.astro";

interface Props {
  lang?: "zh" | "en";
}

const { lang = "zh" } = Astro.props;

const content = {
  zh: {
    headline: "關於我",
    paragraphs: [
      "我是一位前端工程師，熱衷於將設計轉化為高品質的網頁體驗。專注於語意化 HTML、模組化 CSS 架構，以及現代 JavaScript 框架的應用。",
      "重視程式碼的可讀性與可維護性，相信好的前端不只是實現設計稿，更是在效能、無障礙和使用者體驗之間找到最佳平衡。",
    ],
    stats: [
      { value: "3+", label: "年經驗" },
      { value: "10+", label: "專案" },
      { value: "ZH/EN", label: "雙語" },
    ],
  },
  en: {
    headline: "About Me",
    paragraphs: [
      "I'm a frontend developer passionate about turning designs into high-quality web experiences. I focus on semantic HTML, modular CSS architecture, and modern JavaScript frameworks.",
      "I value code readability and maintainability, believing that great frontend development is about finding the perfect balance between performance, accessibility, and user experience.",
    ],
    stats: [
      { value: "3+", label: "Years Exp." },
      { value: "10+", label: "Projects" },
      { value: "ZH/EN", label: "Bilingual" },
    ],
  },
};

const t = content[lang];
---

<section data-theme="light" class="section" id="about">
  <div class="grid">
    <div class="grid-narrow about">
      <div class="about__portrait">
        <div class="about__portrait-placeholder"></div>
      </div>
      <div class="about__content">
        <RevealText delay={0.1}><SectionLabel text="About" /></RevealText>
        <RevealText mb="var(--space-6)"><h2 class="about__headline">{t.headline}</h2></RevealText>
        {t.paragraphs.map((p) => <p class="about__text">{p}</p>)}
        <div class="about__stats">
          {
            t.stats.map((stat) => (
              <div class="about__stat">
                <span class="about__stat-value">{stat.value}</span>
                <span class="about__stat-label">{stat.label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .about {
    display: grid;
    grid-template-columns: 3fr 5fr;
    gap: var(--space-8);
    align-items: start;
  }

  // --------------------------------------------------------------------------
  // Portrait
  // --------------------------------------------------------------------------
  .about__portrait-placeholder {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: var(--color-surface);
    border-radius: var(--radius-12);
  }

  // --------------------------------------------------------------------------
  // Content
  // --------------------------------------------------------------------------
  .about__headline {
    margin-bottom: var(--space-6);
  }

  .about__text {
    font-size: var(--text-body-lg);
    line-height: 1.5;
    color: var(--color-foreground);
    margin-bottom: var(--space-4);
    max-width: var(--container-2xl);
  }

  // --------------------------------------------------------------------------
  // Stats
  // --------------------------------------------------------------------------
  .about__stats {
    display: flex;
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  .about__stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .about__stat-value {
    font-family: var(--font-mono);
    font-size: var(--text-h4);
    font-weight: var(--font-weight-bold);
    color: var(--color-foreground);
  }

  .about__stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    color: var(--color-foreground-muted);
  }

  // --------------------------------------------------------------------------
  // Responsive
  // --------------------------------------------------------------------------
  @media (max-width: 767px) {
    .about {
      grid-template-columns: 1fr;
    }

    .about__portrait-placeholder {
      max-width: 280px;
    }

    .about__stats {
      flex-wrap: wrap;
    }
  }
</style>
