---
// ==========================================================================
// Contact Section
// 來源：Stitch Screen 84213142、design-dna.md
//
// 大標題 + 副標 + 三個聯繫連結（Email / LinkedIn / GitHub）
// 不做表單（CLAUDE.md 規劃：連結 only）
// data-theme="light"
// ==========================================================================

import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  lang?: "zh" | "en";
}

const { lang = "zh" } = Astro.props;

const content = {
  zh: {
    headline: "一起合作",
    subtext: "歡迎聯繫我，無論是合作、提問，或只是打聲招呼。",
  },
  en: {
    headline: "Let's Work Together",
    subtext: "Feel free to reach out for collaboration, questions, or just to say hi.",
  },
};

const t = content[lang];

const links = [
  {
    label: "hello@example.com",
    href: "mailto:hello@example.com",
    icon: "email",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/",
    icon: "linkedin",
  },
  {
    label: "GitHub",
    href: "https://github.com/",
    icon: "github",
  },
];
---

<section data-theme="light" class="section" id="contact">
  <div class="grid">
    <div class="grid-full contact">
      <SectionLabel text="Contact" />
      <h2 class="contact__headline">{t.headline}</h2>
      <p class="contact__subtext">{t.subtext}</p>

      <div class="contact__links">
        {
          links.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith("http") ? "_blank" : undefined}
              rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
              class="contact__link"
            >
              {link.label}
              <span class="contact__link-arrow" aria-hidden="true">↗</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .contact__headline {
    margin-bottom: var(--space-4);
  }

  .contact__subtext {
    font-size: var(--text-body-lg);
    color: var(--color-foreground-muted);
    max-width: var(--container-2xl);
    margin-bottom: var(--space-12);
  }

  // --------------------------------------------------------------------------
  // Contact Links
  // --------------------------------------------------------------------------
  .contact__links {
    display: flex;
    gap: var(--space-12);
  }

  .contact__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-h5);
    font-weight: var(--font-weight-medium);
    color: var(--color-foreground);
    transition: color var(--transition-duration) var(--transition-timing);

    &:hover {
      color: var(--color-brand);
    }
  }

  .contact__link-arrow {
    font-size: var(--text-body);
    opacity: 0.5;
    transition: opacity var(--transition-duration) var(--transition-timing);
  }

  .contact__link:hover .contact__link-arrow {
    opacity: 1;
  }

  // --------------------------------------------------------------------------
  // Responsive
  // --------------------------------------------------------------------------
  @media (max-width: 767px) {
    .contact__links {
      flex-direction: column;
      gap: var(--space-6);
    }
  }
</style>
