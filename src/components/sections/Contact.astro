---
// ==========================================================================
// Contact Section
// 來源：Stitch Screen 84213142、design-dna.md
//
// 左側：大標題 + 副標 + 三個聯繫連結
// 右側：ASCII 視覺效果（frieren-group 4 圖層）
// data-theme="dark"
// ==========================================================================

import SectionLabel from "../ui/SectionLabel.astro";
import RevealText from "../ui/RevealText.astro";

interface Props {
  lang?: "zh" | "en";
}

const { lang = "zh" } = Astro.props;

const content = {
  zh: {
    headline: "一起合作",
    subtext: "歡迎聯繫我，無論是合作、提問，或只是打聲招呼。",
  },
  en: {
    headline: "Let's Work Together",
    subtext: "Feel free to reach out for collaboration, questions, or just to say hi.",
  },
};

const t = content[lang];

const links = [
  {
    label: "hello@example.com",
    href: "mailto:hello@example.com",
    icon: "email",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/",
    icon: "linkedin",
  },
  {
    label: "GitHub",
    href: "https://github.com/",
    icon: "github",
  },
];
---

<section data-theme="dark" class="" id="contact">
  <div class="grid">
    <!-- 左側：文字內容 -->
    <div class="contact__content">
      <RevealText delay={0.1}><SectionLabel text="Contact" /></RevealText>
      <RevealText pt="var(--space-3)" mb="var(--space-4)"><h2 class="contact__headline">{t.headline}</h2></RevealText>
      <p class="contact__subtext" data-fade-up data-fade-trigger=".contact__content">{t.subtext}</p>

      <div class="contact__links">
        {
          links.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith("http") ? "_blank" : undefined}
              rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
              class="contact__link"
            >
              <span data-scramble="scroll hover" data-scramble-group="contact-links" data-scramble-trigger=".contact__content" data-scramble-target=".contact__link" data-scramble-duration="0.4" data-scramble-hold="0.2">{link.label}</span>
              <span class="contact__link-arrow" aria-hidden="true">↗</span>
            </a>
          ))
        }
      </div>
    </div>

    <!-- 右側：ASCII 視覺效果 -->
    <div class="contact__ascii-wrapper">
      <div class="contact__ascii" id="contact-ascii"></div>
      <img src="/images/projects/frieren-group/frieren-group4.png" class="contact__ascii-fallback" id="contact-ascii-fallback" alt="" loading="lazy" />
    </div>
  </div>
</section>

<style lang="scss">
  // --------------------------------------------------------------------------
  // 雙欄佈局
  // --------------------------------------------------------------------------
  .contact__content {
    grid-column: 1 / span 4;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact__ascii-wrapper {
    grid-column: 5 / span 8;
    position: relative;
    aspect-ratio: 1400 / 741; // 匹配 frieren-group 圖片比例
  }

  .contact__ascii {
    position: absolute;
    inset: 0;

    :global(canvas) {
      width: 100%;
      height: 100%;
      display: block;
    }
  }

  .contact__ascii-fallback {
    display: none;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  // --------------------------------------------------------------------------
  // 文字內容
  // --------------------------------------------------------------------------
  .contact__headline {
    margin-bottom: var(--space-4);
  }

  .contact__subtext {
    font-size: var(--text-body-lg);
    color: var(--color-foreground-muted);
    max-width: var(--container-2xl);
    margin-bottom: var(--space-12);
    opacity: 0;
  }

  // --------------------------------------------------------------------------
  // Contact Links
  // --------------------------------------------------------------------------
  .contact__links {
    display: flex;
    gap: var(--space-12);
  }

  .contact__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-h5);
    font-weight: var(--font-weight-medium);
    color: var(--color-foreground);
    transition: color var(--transition-duration) var(--transition-timing);

    &:hover {
      color: var(--color-brand);
    }
  }

  .contact__link-arrow {
    font-size: var(--text-body);
    opacity: 0.5;
    transition: opacity var(--transition-duration) var(--transition-timing);
  }

  .contact__link:hover .contact__link-arrow {
    opacity: 1;
  }

  // --------------------------------------------------------------------------
  // Responsive
  // --------------------------------------------------------------------------
  @media (max-width: 767px) {
    .contact__content {
      grid-column: 1 / span 12;
    }

    .contact__ascii-wrapper {
      display: none;
    }

    .contact__links {
      flex-direction: column;
      gap: var(--space-6);
    }
  }
</style>
