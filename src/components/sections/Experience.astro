---
// ==========================================================================
// Experience Section
// 來源：Stitch Screen 598ec6fc、design-dna.md
//
// 水平三欄式：年份 | 職稱+公司 | 描述
// data-theme="light"
// ==========================================================================

import SectionLabel from "../ui/SectionLabel.astro";
import RevealText from "../ui/RevealText.astro";

interface Props {
  lang?: "zh" | "en";
}

const { lang = "zh" } = Astro.props;

const headline = { zh: "工作經歷", en: "Work Experience" };

const experiences = [
  {
    period: "2021.11 — Present",
    title: { zh: "前端工程師", en: "Frontend Developer" },
    company: { zh: "凱斯整合行銷", en: "Cas Integrated Marketing" },
    description: {
      zh: "服務政府、日商汽車、金融、新創餐飲等客戶，專案類型涵蓋無障礙形象網站、互動動畫網頁、企業後台系統。",
      en: "Delivering websites for government, Japanese automotive, finance, and F&B clients. Projects span accessibility-compliant sites, interactive motion pages, and admin systems.",
    },
  },
  {
    period: "2021.05 — 2021.11",
    title: { zh: "接案前端", en: "Freelance Frontend" },
    company: { zh: "獨立接案", en: "Self-employed" },
    description: {
      zh: "7 個月外包接案，獨立完成多個客戶網站切版與維護，以及一個新創餐飲平台前端開發。",
      en: "7 months of independent client work — delivering markup, maintenance, and a F&B platform frontend.",
    },
  },
  {
    period: "2020.06 — 2021.03",
    title: { zh: "學生", en: "Student" },
    company: { zh: "Lidemy 程式導師實驗計畫", en: "Lidemy Mentor Program" },
    description: {
      zh: "為期 10 個月的系統化前端訓練，從 HTML/CSS、JS 基礎到 React/Redux/Webpack 等現代框架與工具。",
      en: "10-month structured frontend program covering HTML/CSS through React, Redux, and modern build tools.",
    },
  },
  {
    period: "2016.11 — 2020.02",
    title: { zh: "國外業務", en: "International Sales" },
    company: { zh: "紅崴科技（中國廈門）", en: "Hong Wei Tech (Xiamen, China)" },
    description: {
      zh: "3 年中國市場業務經驗，負責代理商招商與課程演講，培養跨領域溝通與專案協調能力。",
      en: "Three years of international sales in mainland China — agency development and training delivery, building cross-functional communication skills.",
    },
  },
];
---

<section data-theme="light" class="section" id="experience">
  <div class="grid">
    <div class="grid-full">
      <RevealText delay={0.1}><SectionLabel text="Experience" /></RevealText>
      <RevealText pt="var(--space-3)" mb="var(--space-12)"><h2 class="experience__headline">{headline[lang]}</h2></RevealText>

      <div class="experience__list">
        {
          experiences.map((exp) => (
            <article class="experience__entry" data-fade-up data-fade-group="experience-entries" data-fade-trigger=".experience__list">
              <span class="experience__period">{exp.period}</span>
              <div class="experience__role">
                <h4 class="experience__title">{exp.title[lang]}</h4>
                <span class="experience__company">{exp.company[lang]}</span>
              </div>
              <p class="experience__desc">{exp.description[lang]}</p>
            </article>
          ))
        }
      </div>
      <!-- Experience 黑圓反色游標 -->
      <div id="experience-cursor" class="experience-cursor" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style lang="scss">
  .experience__headline {
    margin-bottom: var(--space-12);
  }

  // --------------------------------------------------------------------------
  // Entry List
  // --------------------------------------------------------------------------
  .experience__list {
    display: flex;
    flex-direction: column;
  }

  // Mobile-first：單欄；Tablet+ 改為三欄
  .experience__entry {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border-muted);
    opacity: 0;

    &:last-child {
      border-bottom: 1px solid var(--color-border-muted);
    }
  }

  // --------------------------------------------------------------------------
  // Period
  // --------------------------------------------------------------------------
  .experience__period {
    font-family: var(--font-mono);
    font-size: var(--text-h5);
    color: var(--color-foreground-muted);
  }

  // --------------------------------------------------------------------------
  // Role
  // --------------------------------------------------------------------------
  .experience__role {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .experience__title {
    color: var(--color-foreground);
  }

  .experience__company {
    font-size: var(--text-body-lg);
    color: var(--color-foreground-muted);
  }

  // --------------------------------------------------------------------------
  // Description
  // --------------------------------------------------------------------------
  .experience__desc {
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--color-foreground);
  }

  // --------------------------------------------------------------------------
  // Responsive — Tablet+ 切換為三欄佈局
  // --------------------------------------------------------------------------
  @media (min-width: 768px) {
    .experience__entry {
      grid-template-columns: 3fr 5fr 4fr;
      gap: var(--space-8);
    }
  }

  // --------------------------------------------------------------------------
  // Experience Cursor — 黑圓反色
  // --------------------------------------------------------------------------
  .experience-cursor {
    position: fixed;
    top: 0;
    left: 0;
    border-radius: 50%;
    background: #fff;
    mix-blend-mode: difference;
    pointer-events: none;
    z-index: 100;
    will-change: transform, opacity;
  }
</style>
