---
// ==========================================================================
// Hero Section
// 來源：design-dna.md 第 9 節、Stitch Screen f41b24b7
//
// 全螢幕高度、大標題、副標、CTA 按鈕
// data-theme="dark"
// ==========================================================================

import SectionLabel from "../ui/SectionLabel.astro";
import RevealText from "../ui/RevealText.astro";

interface Props {
  lang?: "zh" | "en";
}

const { lang = "zh" } = Astro.props;

const content = {
  zh: {
    tagline: "打造高效能、無障礙且美觀的網頁體驗",
    ctaProjects: "查看作品",
    ctaContact: "聯繫我",
  },
  en: {
    tagline: "Building high-performance, accessible, and beautiful web experiences.",
    ctaProjects: "View Projects",
    ctaContact: "Contact Me",
  },
};

const t = content[lang];
---

<section data-theme="dark" class="hero section" id="hero">
  <!-- ASCII 視覺效果 -->
  <div class="hero__ascii" id="hero-ascii"></div>
  <img src="/images/hero/frieren.png" class="hero__ascii-fallback" id="hero-ascii-fallback" alt="" />
  <div class="grid">
    <div class="grid-full hero__content">
      <RevealText delay={1.2} immediate><SectionLabel text="Hero" /></RevealText>
      <h1>
        <RevealText delay={1} immediate><span class="hero__title">Frontend</span></RevealText>
        <RevealText delay={1.2} mt="-24px" immediate><span class="hero__title" role="doc-subtitle">Developer</span></RevealText>
      </h1>
      <p class="hero__name" data-fade-up data-fade-group="hero-entrance" data-fade-immediate data-fade-delay="1.5">YourName</p>
      <p class="hero__tagline" data-fade-up data-fade-group="hero-entrance" data-fade-immediate data-fade-delay="1">{t.tagline}</p>
      <div class="hero__cta" data-fade-up data-fade-group="hero-entrance" data-fade-immediate data-fade-delay="1">
        <a href="#contact" class="hero__btn hero__btn--primary">
          <span class="hero__btn-inner">
            <span class="hero__btn-icon hero__btn-icon--left" aria-hidden="true">+</span>
            <span class="hero__btn-label" data-scramble="hover" data-scramble-target=".hero__btn--primary" data-scramble-delay="0.2">{t.ctaContact}</span>
            <span class="hero__btn-icon hero__btn-icon--right" aria-hidden="true">+</span>
          </span>
        </a>
        <a href="#projects" class="hero__btn hero__btn--link" data-underline-dir>
          <span class="hero__btn-text">{t.ctaProjects}</span>
          <span class="hero__btn-underline" aria-hidden="true"></span>
        </a>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  // Mobile-first: 上下堆疊（文字在上，ASCII 在下）
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
    padding-top: var(--site-header-height);
    position: relative;
    overflow: hidden;
    background-color: #000;
  }

  // ASCII 視覺效果容器
  // Mobile：相對定位，排在文字下方（order: 2）
  // Tablet+：絕對定位，文字疊在上方
  .hero__ascii {
    position: relative;
    inset: auto;
    order: 2;
    flex: 1;
    min-height: 40vh;
    z-index: 0;

    :global(canvas) {
      width: 100%;
      height: 100%;
      display: block;
    }
  }

  .hero__ascii-fallback {
    display: none;
    position: relative;
    inset: auto;
    order: 2;
    width: 100%;
    height: auto;
    min-height: 40vh;
    object-fit: contain;
    z-index: 0;
  }

  .hero > .grid {
    order: 1;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  // --------------------------------------------------------------------------
  // Tablet+: ASCII 改為全螢幕絕對定位，文字疊在上方
  // --------------------------------------------------------------------------
  @media (min-width: 768px) {
    .hero {
      flex-direction: row;
      align-items: center;
    }

    .hero__ascii {
      position: absolute;
      inset: 0;
      order: initial;
      flex: initial;
      min-height: auto;
    }

    .hero__ascii-fallback {
      position: absolute;
      inset: 0;
      order: initial;
      width: 100%;
      height: 100%;
      min-height: auto;
    }

    .hero > .grid {
      order: initial;
    }

    .hero__content {
      padding-top: 0;
      padding-bottom: 0;
    }
  }

  .hero__title {
    display: inline-block;
    font-size: var(--text-display);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.035em;
    margin-left: -10px;
  }

  .hero__name {
    font-family: var(--font-mono);
    font-size: var(--text-h4);
    color: var(--color-foreground-muted);
    margin-bottom: var(--space-4);
    opacity: 0;
  }

  .hero__tagline {
    font-size: var(--text-body-lg);
    color: var(--color-foreground-muted);
    max-width: var(--container-2xl);
    margin-bottom: var(--space-8);
    opacity: 0;
  }

  .hero__cta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    opacity: 0;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    font-weight: var(--font-weight-medium);
    transition:
      opacity var(--transition-duration) var(--transition-timing),
      background-color var(--transition-duration) var(--transition-timing);

  }

  .hero__btn--primary {
    padding: 0;
    background-color: transparent;
  }

  // --------------------------------------------------------------------------
  // Primary Button — Local tokens
  // --------------------------------------------------------------------------
  $btn-icon-size: 40px;
  $btn-gap: 6px;
  $btn-transition: transform 0.7s cubic-bezier(0.83, 0, 0.17, 1);

  // --------------------------------------------------------------------------
  // Primary Button — Inner (第二層)
  // --------------------------------------------------------------------------
  .hero__btn-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    gap: $btn-gap;
  }

  // --------------------------------------------------------------------------
  // Primary Button — Label & Icon (第三層，各自有背景色)
  // --------------------------------------------------------------------------
  .hero__btn-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: $btn-icon-size;
    padding-inline: var(--space-6);
    background-color: var(--color-brand);
    transition: $btn-transition;
    transform: translateX(calc(-1 * ($btn-icon-size + $btn-gap)));
  }

  .hero__btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: $btn-icon-size;
    height: $btn-icon-size;
    background-color: var(--color-brand);
    transition: $btn-transition;
    font-size: calc(var(--text-body) * 1.2);
  }

  .hero__btn-icon--left {
    transform: rotate(-45deg) scale(0);
  }

  .hero__btn-icon--right {
    position: absolute;
    right: 0;
    top: 0;
    transform: rotate(0deg) scale(1);
  }
  .hero__btn--primary:hover .hero__btn-label {
    transform: translateX(0);
  }
  .hero__btn--primary:hover .hero__btn-icon--left {
    transform: rotate(0deg) scale(1);
  }

  .hero__btn--primary:hover .hero__btn-icon--right {
    transform: rotate(-45deg) scale(0);
  }

  // --------------------------------------------------------------------------
  // Link Button — 單條底線 + JS 控制方向
  // --------------------------------------------------------------------------
  $link-transition-duration: 0.7s;
  $link-timing: cubic-bezier(0.625, 0.05, 0, 1);

  .hero__btn--link {
    position: relative;
    line-height: 1.5;
    color: var(--color-foreground);
  }

  .hero__btn-text {
    display: inline-block;
  }

  .hero__btn-underline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 1px;
    background-color: currentColor;
    transform: scaleX(1);
    transform-origin: left;
    transition: transform $link-transition-duration $link-timing;
  }
</style>

<script>
  // --------------------------------------------------------------------------
  // Link Underline — hover in/out 皆從左往右
  // mouseenter: 底線從左縮回（origin-left, scaleX 1→0）
  //             transitionend 後從左展開（origin-left, scaleX 0→1）
  // mouseleave: 同樣方向重複一次
  // --------------------------------------------------------------------------
  let underlineAbort: AbortController | null = null;

  function initUnderlineLinks() {
    underlineAbort?.abort();
    underlineAbort = new AbortController();
    const { signal } = underlineAbort;

    document.querySelectorAll<HTMLElement>("[data-underline-dir]").forEach((link) => {
      const lineEl = link.querySelector<HTMLElement>(".hero__btn-underline");
      if (!lineEl) return;

      let isAnimating = false;

      function animateOut() {
        isAnimating = true;
        lineEl.style.transformOrigin = "right";
        lineEl.style.transform = "scaleX(0)";
      }

      function onShrinkEnd(e: TransitionEvent) {
        if (e.propertyName !== "transform") return;
        lineEl.removeEventListener("transitionend", onShrinkEnd);

        lineEl.style.transition = "none";
        lineEl.style.transformOrigin = "left";
        lineEl.style.transform = "scaleX(0)";

        void lineEl.offsetWidth;
        lineEl.style.transition = "";
        lineEl.style.transform = "scaleX(1)";

        isAnimating = false;
      }

      link.addEventListener("mouseenter", () => {
        if (isAnimating) return;
        lineEl.addEventListener("transitionend", onShrinkEnd);
        animateOut();
      }, { signal });

      link.addEventListener("mouseleave", () => {
        if (isAnimating) return;
        lineEl.addEventListener("transitionend", onShrinkEnd);
        animateOut();
      }, { signal });
    });
  }

  initUnderlineLinks();
  document.addEventListener("astro:page-load", initUnderlineLinks);
</script>
