---
// ==========================================================================
// Projects Section
// 來源：Stitch Screen c6291bcb、design-dna.md
//
// 2x2 卡片 Grid，從 Content Collections 讀取專案資料
// data-theme="light"
// ==========================================================================

import { getCollection } from "astro:content";
import SectionLabel from "../ui/SectionLabel.astro";

interface Props {
  lang?: "zh" | "en";
}

const { lang = "zh" } = Astro.props;

const headline = { zh: "精選作品", en: "Selected Work" };
const viewAll = { zh: "查看所有作品 →", en: "View All Projects →" };

// 從對應語言的 Collection 讀取專案
const collectionName = `projects-${lang}` as "projects-zh" | "projects-en";
const projects = (await getCollection(collectionName))
  .sort((a, b) => a.data.order - b.data.order);
---

<section data-theme="light" class="section" id="projects">
  <div class="grid">
    <div class="grid-full">
      <SectionLabel text="Projects" />
      <h2 class="projects__headline">{headline[lang]}</h2>

      <div class="projects__grid">
        {
          projects.map((project) => (
            <a href={`/${lang}/projects/${project.data.slug}`} class="project-card">
              <div class="project-card__image" />
              <div class="project-card__info">
                <div class="project-card__header">
                  <h4 class="project-card__title">{project.data.title}</h4>
                  <span
                    class={`project-card__status project-card__status--${project.data.status}`}
                  >
                    <span class="project-card__status-dot" aria-hidden="true" />
                    {project.data.status === "online" ? "Online" : "Offline"}
                  </span>
                </div>
                <p class="project-card__desc">{project.data.description}</p>
                <div class="project-card__tags">
                  {project.data.tags.map((tag: string) => (
                    <span class="project-card__tag">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .projects__headline {
    margin-bottom: var(--space-12);
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  // --------------------------------------------------------------------------
  // Project Card
  // --------------------------------------------------------------------------
  .project-card {
    display: block;
    transition: opacity var(--transition-duration) var(--transition-timing);

    &:hover {
      opacity: 0.8;
    }
  }

  .project-card__image {
    width: 100%;
    aspect-ratio: 16 / 10;
    background-color: var(--color-surface);
    border-radius: var(--radius-12);
    margin-bottom: var(--space-4);
  }

  .project-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .project-card__title {
    font-size: var(--text-h4);
  }

  .project-card__status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-foreground-muted);
  }

  .project-card__status-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    display: inline-block;
  }

  .project-card__status--online .project-card__status-dot {
    background-color: #22c55e;
  }

  .project-card__status--offline .project-card__status-dot {
    background-color: var(--color-foreground-muted);
  }

  .project-card__desc {
    font-size: var(--text-body);
    color: var(--color-foreground-muted);
    margin-bottom: var(--space-3);
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .project-card__tag {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border-muted);
    border-radius: var(--radius-full);
    color: var(--color-foreground-muted);
  }

  @media (max-width: 767px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
