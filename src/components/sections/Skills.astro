---
// ==========================================================================
// Skills Section
// 來源：Stitch Screen 1e9f00ca、design-dna.md 第 12 節（修正紀錄）
//
// 分類 Grid + pill 標籤（正方形標記 ■）
// data-theme="light"
// ==========================================================================

import SectionLabel from "../ui/SectionLabel.astro";
import RevealText from "../ui/RevealText.astro";

interface Props {
  lang?: "zh" | "en";
}

const { lang = "zh" } = Astro.props;

const headline = { zh: "技能與工具", en: "Skills & Tools" };

const categories = [
  {
    name: { zh: "前端", en: "Frontend" },
    skills: ["HTML", "CSS/SCSS", "JavaScript", "TypeScript", "React", "Redux", "Astro", "Bootstrap", "jQuery"],
  },
  {
    name: { zh: "互動動畫", en: "Animation" },
    skills: ["GSAP", "Lottie", "CSS Animation", "Three.js"],
  },
  {
    name: { zh: "後端", en: "Backend" },
    skills: ["Node.js", "MySQL", "PHP", "Express"],
  },
  {
    name: { zh: "工具 & AI", en: "Tools & AI" },
    skills: ["Git", "Webpack", "Vite", "Claude Code", "Windsurf"],
  },
];
---

<section data-theme="light" class="section" id="skills">
  <div class="grid">
    <div class="grid-full">
      <RevealText delay={0.1}><SectionLabel text="Skills" /></RevealText>
      <RevealText pt="var(--space-3)" mb="var(--space-12)"><h2 class="skills__headline">{headline[lang]}</h2></RevealText>

      <div class="skills__grid">
        {
          categories.map((cat) => (
            <div class="skills__category" data-fade-up data-fade-group="skills-categories" data-fade-trigger=".skills__grid">
              <h5 class="skills__category-name">
                <span class="skills__category-marker" aria-hidden="true">■</span>
                {cat.name[lang]}
              </h5>
              <div class="skills__tags">
                {cat.skills.map((skill) => (
                  <span class="skills__tag">{skill}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .skills__headline {
    margin-bottom: var(--space-12);
  }

  // --------------------------------------------------------------------------
  // Category Grid
  // --------------------------------------------------------------------------
  .skills__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  .skills__category {
    opacity: 0;
    background-color: #141314;
    color: #eee;
    padding: var(--space-6);
    border-radius: var(--radius-lg);
  }

  .skills__category-name {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    margin-bottom: var(--space-6);
  }

  .skills__category-marker {
    color: var(--color-brand);
    font-size: 0.5rem;
    line-height: 1;
  }

  // --------------------------------------------------------------------------
  // Tags
  // --------------------------------------------------------------------------
  .skills__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .skills__tag {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    color: #eee;
    padding: var(--space-2) var(--space-4);
    border: 1px solid rgba(238, 238, 238, 0.102);
    border-radius: var(--radius-full);
  }

  // --------------------------------------------------------------------------
  // Responsive — Mobile-first（1→2→4 欄）
  // --------------------------------------------------------------------------
  @media (min-width: 768px) {
    .skills__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .skills__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
