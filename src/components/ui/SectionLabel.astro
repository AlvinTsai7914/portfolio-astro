---
// ==========================================================================
// SectionLabel — 代碼註解風格標籤（如 "// About"）
// 來源：docs/design-dna.md 第 10 節
// ==========================================================================

interface Props {
  text: string;
  scramble?: "immediate" | "scroll" | "hover";
  scrambleDelay?: number;
  scrambleDuration?: number;
  scrambleHold?: number;
}

const { text, scramble, scrambleDelay, scrambleDuration, scrambleHold } = Astro.props;
---

<span
  class="section-label"
  {...scramble ? {
    "data-scramble": scramble,
    ...(scrambleDelay ? { "data-scramble-delay": String(scrambleDelay) } : {}),
    ...(scrambleDuration ? { "data-scramble-duration": String(scrambleDuration) } : {}),
    ...(scrambleHold ? { "data-scramble-hold": String(scrambleHold) } : {}),
  } : {}}
>// {text}</span>

<style lang="scss">
  .section-label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    color: var(--color-foreground-muted);
    margin-bottom: var(--space-4);
  }
</style>
