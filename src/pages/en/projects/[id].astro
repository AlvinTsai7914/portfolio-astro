---
// ==========================================================================
// English Project Detail Page — Case Study
// Route: /en/projects/[slug]
// ==========================================================================

import { getCollection, render } from "astro:content";
import BaseLayout from "../../../components/layout/BaseLayout.astro";
import RevealText from "../../../components/ui/RevealText.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects-en");

  return projects.map((project) => ({
    params: { id: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Alvin Tsai`} description={project.data.description} lang="en">
  <article class="case-study" data-theme="light">
    <header class="case-study__hero section" data-theme="dark">
      <div class="grid">
        <div class="grid-full">
          <a href="/en/#projects" class="case-study__back">← Back to Projects</a>
          <RevealText immediate mb="var(--space-4)"><h1 class="case-study__title">{project.data.title}</h1></RevealText>
          <RevealText immediate delay={0.2} mb="var(--space-8)"><p class="case-study__desc">{project.data.description}</p></RevealText>
          <div class="case-study__meta">
            <div class="case-study__tags">
              {project.data.tags.map((tag: string) => (
                <span class="case-study__tag">{tag}</span>
              ))}
            </div>
            <div class="case-study__links">
              {project.data.status === "online" && project.data.liveUrl && (
                <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="case-study__link case-study__link--primary">
                  Live Demo ↗
                </a>
              )}
              {project.data.sourceUrl && (
                <a href={project.data.sourceUrl} target="_blank" rel="noopener noreferrer" class="case-study__link">
                  Source Code ↗
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="case-study__cover" data-theme="light">
      <div class="grid">
        <div class="grid-full">
          <div class="case-study__cover-image"></div>
        </div>
      </div>
    </div>

    <div class="case-study__content section" data-theme="light">
      <div class="grid">
        <div class="grid-narrow">
          <div class="case-study__prose">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style lang="scss">
  .case-study__hero {
    padding-top: calc(var(--site-header-height) + var(--space-16));
  }

  .case-study__back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    color: var(--color-foreground-muted);
    margin-bottom: var(--space-8);
    transition: color var(--transition-duration) var(--transition-timing);

    &:hover {
      color: var(--color-foreground);
    }
  }

  .case-study__title {
    font-size: var(--text-h1);
  }

  .case-study__desc {
    font-size: var(--text-body-lg);
    color: var(--color-foreground-muted);
    max-width: var(--container-2xl);
  }

  // Mobile-first：垂直堆疊；Tablet+ 改水平
  .case-study__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .case-study__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .case-study__tag {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-foreground-muted);
  }

  .case-study__links {
    display: flex;
    gap: var(--space-4);
  }

  .case-study__link {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    font-weight: var(--font-weight-medium);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-8);
    border: 1px solid var(--color-foreground);
    color: var(--color-foreground);
    transition:
      background-color var(--transition-duration) var(--transition-timing),
      color var(--transition-duration) var(--transition-timing);

    &:hover {
      background-color: var(--color-foreground);
      color: var(--color-background);
    }
  }

  .case-study__link--primary {
    background-color: var(--color-brand);
    border-color: var(--color-brand);
    color: var(--color-white);

    &:hover {
      opacity: 0.85;
      background-color: var(--color-brand);
      color: var(--color-white);
    }
  }

  .case-study__cover {
    padding-block: var(--space-8);
  }

  .case-study__cover-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: var(--color-surface);
    border-radius: var(--radius-12);
  }

  .case-study__prose {
    :global(h2) {
      font-size: var(--text-h3);
      margin-top: var(--space-12);
      margin-bottom: var(--space-4);
    }

    :global(h3) {
      font-size: var(--text-h4);
      margin-top: var(--space-8);
      margin-bottom: var(--space-3);
    }

    :global(p) {
      font-size: var(--text-body-lg);
      line-height: 1.7;
      color: var(--color-foreground);
      margin-bottom: var(--space-4);
    }

    :global(ul),
    :global(ol) {
      margin-bottom: var(--space-4);
      padding-left: var(--space-6);
      list-style: disc;
    }

    :global(li) {
      font-size: var(--text-body-lg);
      line-height: 1.7;
      margin-bottom: var(--space-2);
    }

    :global(code) {
      font-family: var(--font-mono);
      font-size: 0.9em;
      background-color: var(--color-background-muted);
      padding: 0.15em 0.4em;
      border-radius: var(--radius-4);
    }

    :global(strong) {
      font-weight: var(--font-weight-bold);
    }
  }

  // Responsive — Tablet+ 水平排列
  @media (min-width: 768px) {
    .case-study__meta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
